<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MOST18: Protect Your Family | Ms. Zata</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A96E;
    --gold-light: #E8D5B0;
    --gold-dark: #9A7A4A;
    --navy: #0D1B2A;
    --navy-mid: #1A2E42;
    --navy-light: #243D57;
    --cream: #FAF7F2;
    --cream-dark: #F0EBE0;
    --text-dark: #1A1208;
    --text-mid: #4A3F2F;
    --text-muted: #7A6E5F;
    --white: #FFFFFF;
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'DM Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--cream);
    color: var(--text-dark);
    font-size: 16px;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ── TOP BAR ── */
  .topbar {
    background: var(--navy);
    color: var(--gold-light);
    text-align: center;
    font-size: 13px;
    letter-spacing: 0.08em;
    padding: 10px 20px;
    font-weight: 300;
  }

  /* ── NAV ── */
  nav {
    background: var(--white);
    border-bottom: 1px solid var(--cream-dark);
    padding: 18px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: 0.02em;
  }
  .nav-logo span { color: var(--gold-dark); }
  .nav-cta {
    background: var(--navy);
    color: var(--gold-light);
    border: none;
    padding: 10px 24px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.06em;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s, color 0.2s;
  }
  .nav-cta:hover { background: var(--gold-dark); color: var(--white); }

  /* ── HERO ── */
  .hero {
    background: var(--navy);
    position: relative;
    overflow: hidden;
    padding: 80px 40px;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }
  .hero-img-wrap {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
  }
  .hero-img-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(13,27,42,0.35) 0%, rgba(13,27,42,0) 60%);
    z-index: 1;
  }
  .hero-img-wrap img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center top;
    display: block;
    border-left: 3px solid rgba(201,169,110,0.4);
  }
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 36px; }
    .hero-img-wrap { order: -1; }
    .hero-img-wrap img { height: 280px; border-left: none; border-top: 3px solid rgba(201,169,110,0.4); }
  }
  .hero::before { content: none; }
  .hero::after { content: none; }
  .hero-inner {
    position: relative;
    z-index: 2;
  }
  .hero-tag {
    display: inline-block;
    border: 1px solid rgba(201,169,110,0.5);
    color: var(--gold);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 16px;
    margin-bottom: 32px;
    font-weight: 400;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 68px);
    font-weight: 500;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--gold);
  }
  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.65);
    font-weight: 300;
    margin-bottom: 48px;
    max-width: 560px;
    line-height: 1.75;
  }

  /* ── OPT-IN CARD ── */
  .optin-card {
    background: var(--white);
    border-top: 3px solid var(--gold);
    padding: 24px 40px;
    max-width: 480px;
  }
  .optin-card h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .optin-card p {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 24px;
    font-weight: 300;
  }
  .form-group { margin-bottom: 14px; }
  .form-group input {
    width: 100%;
    padding: 13px 16px;
    border: 1px solid #DDD5C8;
    background: var(--cream);
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-dark);
    outline: none;
    transition: border-color 0.2s;
  }
  .form-group input:focus { border-color: var(--gold); }
  .form-group input::placeholder { color: var(--text-muted); font-weight: 300; }
  .btn-primary {
    width: 100%;
    background: var(--gold-dark);
    color: var(--white);
    border: none;
    padding: 15px 24px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    margin-top: 4px;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--navy); }
  .optin-note {
    font-size: 11px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 12px;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  /* ── TRUST STRIP ── */
  .trust-strip {
    background: var(--cream-dark);
    border-top: 1px solid #E0D8CE;
    border-bottom: 1px solid #E0D8CE;
    padding: 20px 40px;
    display: flex;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-mid);
    font-weight: 400;
  }
  .trust-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--gold-dark);
  }

  /* ── SECTIONS ── */
  section { padding: 80px 40px; }
  .section-inner { max-width: 820px; margin: 0 auto; }
  .section-tag {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-dark);
    font-weight: 500;
    margin-bottom: 12px;
    display: block;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 500;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }
  .section-title em { font-style: italic; color: var(--gold-dark); }
  .section-body {
    font-size: 16px;
    color: var(--text-mid);
    font-weight: 300;
    max-width: 620px;
    margin-bottom: 48px;
  }

  /* ── PAIN SECTION ── */
  .pain-section { background: var(--white); }
  .pain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2px;
    margin-bottom: 48px;
  }
  .pain-card {
    background: var(--cream);
    padding: 28px 24px;
    border-left: 3px solid transparent;
    transition: border-color 0.2s;
  }
  .pain-card:hover { border-left-color: var(--gold); }
  .pain-card-icon {
    font-size: 24px;
    margin-bottom: 12px;
    display: block;
  }
  .pain-card h4 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .pain-card p {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 300;
    line-height: 1.65;
  }
  .familiar-box {
    background: var(--navy);
    padding: 32px 36px;
    border-left: 4px solid var(--gold);
  }
  .familiar-box h4 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 16px;
    font-style: italic;
  }
  .familiar-box ul {
    list-style: none;
    margin-bottom: 20px;
  }
  .familiar-box ul li {
    font-size: 15px;
    color: rgba(255,255,255,0.75);
    font-weight: 300;
    padding: 6px 0;
    padding-left: 20px;
    position: relative;
  }
  .familiar-box ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
  }
  .familiar-box .result {
    font-size: 14px;
    color: var(--gold-light);
    letter-spacing: 0.04em;
    font-style: italic;
    font-family: var(--font-display);
    font-size: 17px;
  }

  /* ── TRANSFORMATION ── */
  .transform-section { background: var(--cream); }
  .transform-list { display: flex; flex-direction: column; gap: 2px; }
  .transform-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    background: var(--white);
    padding: 22px 24px;
    border-bottom: 1px solid var(--cream-dark);
  }
  .transform-num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    color: var(--gold-light);
    line-height: 1;
    flex-shrink: 0;
    width: 36px;
    margin-top: -4px;
  }
  .transform-text h4 {
    font-size: 15px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 4px;
  }
  .transform-text p {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 300;
  }

  /* ── HOW IT WORKS ── */
  .steps-section { background: var(--navy); }
  .steps-section .section-title { color: var(--white); }
  .steps-section .section-body { color: rgba(255,255,255,0.5); }
  .steps-section .section-tag { color: var(--gold); }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }
  @media (max-width: 640px) { .steps-grid { grid-template-columns: 1fr; } }
  .step-card {
    background: var(--navy-mid);
    padding: 36px 28px;
    position: relative;
    overflow: hidden;
  }
  .step-card::before { content: none; }
  .step-num {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 600;
    color: rgba(201,169,110,0.15);
    line-height: 1;
    margin-bottom: 16px;
    display: block;
  }
  .step-card h4 {
    font-size: 15px;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 10px;
    letter-spacing: 0.02em;
  }
  .step-card p {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    font-weight: 300;
    line-height: 1.65;
  }
  .step-divider {
    display: none;
  }

  /* ── ABOUT ── */
  .about-section { background: var(--white); }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 60px;
    align-items: center;
  }
  @media (max-width: 680px) { .about-grid { grid-template-columns: 1fr; } }
  .about-img-wrap {
    position: relative;
  }
  .about-img-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--cream-dark);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: visible;
    position: relative;
  }
  .about-img-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
  .about-badge {
    position: absolute;
    bottom: -16px;
    right: -16px;
    background: var(--gold-dark);
    color: var(--white);
    padding: 14px 18px;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    line-height: 1.5;
    text-align: center;
  }
  .about-content .section-tag { display: block; }
  .about-content .section-title { margin-bottom: 20px; }
  .about-content p {
    font-size: 15px;
    color: var(--text-mid);
    font-weight: 300;
    margin-bottom: 16px;
    line-height: 1.8;
  }
  .credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }
  .cred-pill {
    background: var(--cream);
    border: 1px solid var(--cream-dark);
    font-size: 12px;
    color: var(--text-mid);
    padding: 6px 14px;
    font-weight: 400;
    letter-spacing: 0.03em;
  }

  /* ── PRODUCT FEATURES ── */
  .features-section { background: var(--cream); }
  .features-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 680px) { .features-grid { grid-template-columns: 1fr; } }
  .feature-list { display: flex; flex-direction: column; gap: 16px; }
  .feature-item {
    display: flex;
    gap: 16px;
    padding: 20px;
    background: var(--white);
    border-left: 2px solid var(--gold);
  }
  .feature-icon {
    width: 36px;
    height: 36px;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .feature-icon svg { width: 16px; height: 16px; }
  .feature-item h4 {
    font-size: 14px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 4px;
  }
  .feature-item p {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 300;
    line-height: 1.6;
  }
  .pdf-card {
    background: var(--navy);
    padding: 36px 32px;
    position: sticky;
    top: 80px;
  }
  .pdf-card-tag {
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: block;
  }
  .pdf-card h3 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 24px;
    line-height: 1.3;
    font-style: italic;
  }
  .pdf-benefit {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .pdf-benefit:last-child { border-bottom: none; }
  .check {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .pdf-benefit span {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    font-weight: 300;
    line-height: 1.5;
  }

  /* ── TESTIMONIALS ── */
  .testimonials-section { background: var(--white); }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2px;
  }
  .testimonial-card {
    background: var(--cream);
    padding: 32px 28px;
    position: relative;
  }
  .quote-mark {
    font-family: var(--font-display);
    font-size: 80px;
    color: var(--gold-light);
    line-height: 0.6;
    display: block;
    margin-bottom: 20px;
    font-weight: 400;
  }
  .testimonial-card blockquote {
    font-size: 15px;
    color: var(--text-mid);
    font-weight: 300;
    line-height: 1.75;
    margin-bottom: 20px;
    font-style: italic;
    font-family: var(--font-display);
    font-size: 17px;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 500;
    color: var(--gold-light);
    flex-shrink: 0;
  }
  .author-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--navy);
  }
  .author-role {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 300;
  }

  /* ── FAQ ── */
  .faq-section { background: var(--cream); }
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2px;
  }
  .faq-item {
    background: var(--white);
    padding: 24px 28px;
    border-left: 2px solid var(--cream-dark);
    transition: border-color 0.2s;
  }
  .faq-item:hover { border-left-color: var(--gold); }
  .faq-item h4 {
    font-size: 15px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .faq-item p {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 300;
    line-height: 1.65;
  }

  /* ── FINAL CTA ── */
  .cta-section {
    background: var(--navy);
    padding: 100px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before { content: none; }
  .cta-section::after { content: none; }
  .cta-section .section-inner { position: relative; z-index: 2; }
  .cta-section .section-tag { color: var(--gold); }
  .cta-section .section-title { color: var(--white); margin-bottom: 16px; }
  .cta-section .section-body { color: rgba(255,255,255,0.55); margin: 0 auto 40px; }
  .cta-optin {
    max-width: 420px;
    margin: 0 auto;
  }
  .cta-optin .form-group input {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(201,169,110,0.3);
    color: var(--white);
  }
  .cta-optin .form-group input::placeholder { color: rgba(255,255,255,0.35); }
  .cta-optin .form-group input:focus { border-color: var(--gold); }
  .btn-gold {
    width: 100%;
    background: var(--gold-dark);
    color: var(--white);
    border: none;
    padding: 16px 24px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 4px;
  }
  .btn-gold:hover { background: var(--gold); }
  .cta-share {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .cta-share p {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
    margin-bottom: 16px;
    font-weight: 300;
  }
  .share-buttons {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .share-btn {
    padding: 10px 20px;
    border: 1px solid rgba(201,169,110,0.35);
    background: transparent;
    color: var(--gold-light);
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    font-weight: 400;
  }
  .share-btn:hover { background: rgba(201,169,110,0.15); }

  /* ── FOOTER ── */
  footer {
    background: var(--text-dark);
    padding: 32px 40px;
    text-align: center;
    color: rgba(255,255,255,0.3);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.04em;
  }
  footer a { color: rgba(255,255,255,0.45); text-decoration: none; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-inner > * {
    animation: fadeUp 0.7s ease both;
  }
  .hero-inner > *:nth-child(1) { animation-delay: 0.1s; }
  .hero-inner > *:nth-child(2) { animation-delay: 0.25s; }
  .hero-inner > *:nth-child(3) { animation-delay: 0.35s; }
  .hero-inner > *:nth-child(4) { animation-delay: 0.45s; }

  /* ── RESPONSIVE / MOBILE ── */
  @media (max-width: 768px) {
    /* Global */
    section { padding: 52px 20px; }
    .section-inner { max-width: 100%; }
    .section-title { font-size: clamp(28px, 7vw, 40px); }

    /* Topbar */
    .topbar { font-size: 11px; letter-spacing: 0.04em; padding: 8px 16px; }

    /* Nav */
    nav { padding: 14px 20px; }
    .nav-logo { font-size: 18px; }
    .nav-cta { padding: 8px 16px; font-size: 12px; }

    /* Urgency bar */
